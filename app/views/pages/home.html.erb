<% content_for :sidebar do %>
    <%= image_tag "logo.png", alt: "", class: "img-fluid w-40 p-2"%>
    <hr class="border-light"> 
    <div class="px-2">
        <h5 class="text-white text-uppercase">FILTROS DE COLECCIÓN</h6>
        <br>
        <div class="form-group">
            <label for="genreSelect" class="text-white">Género</label>
            <select class="form-control" id="genreSelect">
                <option selected>Todos</option>
                <% Genre.all.each do |genre| %>
                    <option value="<%= genre.id %>"><%= genre.name %></option>
                <% end %>
            </select>
        </div>
        <br>
        <div class="form-group">
            <label for="artistSelect" class="text-white">Artista</label>
            <select class="form-control" id="artistSelect">
                <option selected>Todos</option>
            </select>
        </div>
        <br>
        <div class="form-group">
            <label for="albumSelect" class="text-white">Álbum</label>
            <select class="form-control" id="albumSelect">
                <option selected>Todos</option>
                <% Album.all.each do |album| %>
                    <option value="<%= album.id %>"><%= album.name %></option>
                <% end %>
            </select>
        </div>
        <br>
        <div class="form-group">
            <label for="yearSelect" class="text-white">Año</label>
            <select class="form-control" id="yearSelect">
                <option selected>Todos</option>
            </select>
        </div>
    </div>
<% end %>

<div id="mainContent" class="container-fluid"> 
    <!-- Encabezado -->
    <div class="row mt-4"> 
        <div class="col-md-12">
            <div class="d-flex align-items-center">
                <div class="logo-container">
                    <%= image_tag "music.png", alt: "", class: "img-fluid" %> 
                </div> 
                <div class="ml-3">
                    <h2 class="text-primary">Collección de música</h2> 
                </div>
            </div>
        </div>
        <hr class="w-100">
    </div>

    <!-- Botón CRUD -->
    <div class="floating-crud-btn-container">
        <button class="btn btn-primary dropdown-toggle" type="button" id="floatingMenuButton" data-bs-toggle="dropdown" aria-expanded="false">
            Opciones
        </button>   
        <ul class="dropdown-menu" aria-labelledby="floatingMenuButton">
            <li>  <a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#exampleModal" data-turbo-frame="genre_modal" data-action="new">Géneros</a></li>
            <li><a class="dropdown-item" href="#">Autores</a></li>
            <li><a class="dropdown-item" href="#">Albums</a></li>
        </ul>       
    </div>
    
    <!-- Grid de imágenes -->
    <div class="row">
        <div class="col-md-4">
            <div class="card">
                <%= image_tag "Pink_floy_Dark_side.jpeg", class: "card-img-top", alt: "Image 1" %>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <%= image_tag "king_crimson_inthecourt.jpeg", class: "card-img-top", alt: "Image 2" %>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <%= image_tag "genesis_foxtrot.jpeg", class: "card-img-top", alt: "Image 2" %>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <%= image_tag "KBB_Lost_and_found.jepg.jpg", class: "card-img-top", alt: "Image 2" %>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <%= image_tag "le_orme_uomodipezza.jpeg", class: "card-img-top", alt: "Image 2" %>
            </div>
        </div>
    </div>

    <!-- Ventana para dar de alta un género -->
    <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="exampleModalLabel">Modal Title</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <%= turbo_frame_tag "genre_modal" %>
                  </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                    <button type="button" class="btn btn-primary">Save changes</button>
                </div>
            </div>
        </div>
    </div>
</div>