<p style="color: green"><%= notice %></p>

<h1>Géneros</h1>
<table>
  <thead>
  <tr>
    <th>Name</th>
    <th colspan="3"></th>
  </tr>
  </thead>
  <tbody>
    <% @genres.each do |genre| %>
      <tr>
        <td><%= genre.name %></td>
        <td><%= link_to 'Show', genre %></td>  
        <td><%= link_to 'Edit', edit_genre_path(genre) %></td> 
        <td><%= button_to "Destroy", genre, method: :delete, data: { confirm: "Are you sure?" } %></td> 
      </tr>
    <% end %>
  </tbody>
</table>

<br>

<div>
  <%= link_to 'New genre', new_genre_path, class: "btn btn-secondary" %>
</div>
<br>
<div>
  <%= link_to "Volver a la colección", root_path, class: "btn btn-secondary" %>
</div>